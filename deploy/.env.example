# =============================================================================
# Taarifu — local development environment template.
#
# Copy this file to the REPO ROOT as `.env` (docker compose auto-loads ./.env):
#     cp deploy/.env.example .env
#
# Then fill the two REQUIRED secrets below. This file contains NO real secrets —
# only documented placeholders (PRD §18, CLAUDE.md §12). `.env` is git-ignored.
# =============================================================================

# --- Database (local PostgreSQL 16 + PostGIS 3.4 container) ---
POSTGRES_DB=taarifu
POSTGRES_USER=taarifu
# Local-only DB password (NOT a production secret).
POSTGRES_PASSWORD=taarifu

# --- Host port mappings (override if a port is already taken locally) ---
DB_HOST_PORT=5432
REDIS_HOST_PORT=6379
BACKEND_HOST_PORT=8081

# --- REQUIRED secrets (no defaults; backend + compose fail fast if absent) ---
# Generate strong values, do NOT reuse these examples:
#   TAARIFU_JWT_SECRET=$(openssl rand -base64 48)
#   TAARIFU_CRYPTO_DEV_KEY=$(openssl rand -base64 32)
TAARIFU_JWT_SECRET=
TAARIFU_CRYPTO_DEV_KEY=

# --- Optional (safe local defaults applied by docker-compose.yml if omitted) ---
TAARIFU_JWT_ISSUER=taarifu
TAARIFU_JWT_AUDIENCE=taarifu-clients
# CORS allow-list: explicit origins only, comma-separated. NEVER '*' with credentials.
TAARIFU_CORS_ORIGINS=http://localhost:4200
# Geocoder adapter: 'stub' (local, no boundaries) or 'postgis' (source of truth).
TAARIFU_GEOCODER=stub
# Identity verification adapter (D-Q2): 'operator-assisted' or 'auto-stub'.
TAARIFU_VERIFICATION_PROVIDER=operator-assisted
