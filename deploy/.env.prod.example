# =============================================================================
# Taarifu — PRODUCTION env template for deploy/docker-compose.prod.yml.
#
# Copy to deploy/.env.prod and fill in. This file contains NO real secrets — only
# documented placeholders (PRD §18, CLAUDE.md §12). deploy/.env.prod is git-ignored.
#
#   cp deploy/.env.prod.example deploy/.env.prod
#   # then fill every REQUIRED value from the secret manager (Vault / cloud KMS).
#
# DO NOT commit deploy/.env.prod. In a real deployment, prefer injecting these from
# the secret manager at runtime over a file on disk. Rotate JWT/crypto keys per policy.
# =============================================================================

# --- Environment label (stamped onto metrics/alerts) ---
TAARIFU_ENV=prod

# --- Image to run (immutable, already SCANNED by CI). Promote the SAME artefact. ---
# Rollback = set this to the previous good tag and `up -d` again (deploy/README §8).
TAARIFU_IMAGE=ghcr.io/<org>/taarifu-backend:<git-sha>

# --- Database (REQUIRED — no defaults) ---
POSTGRES_DB=taarifu
POSTGRES_USER=taarifu
# Strong, unique. From the secret manager — never reuse a dev value.
POSTGRES_PASSWORD=

# --- Required application secrets (REQUIRED — backend fails fast if absent) ---
#   TAARIFU_JWT_SECRET=$(openssl rand -base64 48)      # >= 256-bit
#   TAARIFU_CRYPTO_DEV_KEY=$(openssl rand -base64 32)  # replace with a real KMS adapter for prod PII (EI-19)
TAARIFU_JWT_SECRET=
TAARIFU_CRYPTO_DEV_KEY=

# --- CORS allow-list (REQUIRED) — explicit prod origins ONLY, never '*'+credentials ---
TAARIFU_CORS_ORIGINS=https://admin.taarifu.example,https://app.taarifu.example

# --- Optional (safe prod defaults applied by compose if omitted) ---
TAARIFU_JWT_ISSUER=taarifu
TAARIFU_JWT_AUDIENCE=taarifu-clients
# Source-of-truth geocoder in prod (requires seeded ward boundaries).
TAARIFU_GEOCODER=postgis
TAARIFU_VERIFICATION_PROVIDER=operator-assisted
# MFA second factor MUST stay enforced in prod (N-4). Leave true. NEVER set false in prod.
TAARIFU_MFA_ENFORCED=true

# --- Host port mappings ---
BACKEND_HOST_PORT=8081
GRAFANA_HOST_PORT=3000

# --- Grafana (REQUIRED) — admin password from the secret manager ---
GRAFANA_ADMIN_PASSWORD=
